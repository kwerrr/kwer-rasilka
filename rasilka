#  AIOGRAM — ХЭНДЛЕРЫ
# ═══════════════════════════════════════════════════════════════════════════════
def only_owner(uid: int) -> bool:
    """Пропускаем только владельца (если OWNER_ID задан)."""
    if OWNER_ID == 0:
        return True   # без ограничений
    return uid == OWNER_ID

def register_handlers(dp: Dispatcher, manager: BroadcastManager, aiogram_bot: Bot):

    # ── /start ────────────────────────────────────────────────────────────
    @dp.message(CommandStart())
    async def cmd_start(msg: Message, state: FSMContext):
        if not only_owner(msg.from_user.id):
            return await msg.answer("⛔ Нет доступа.")
        await state.clear()
        await msg.answer(
            "📢 <b>Рассылка от лица аккаунта</b>\n\nВыберите действие:",
            parse_mode="HTML", reply_markup=kb_main()
        )

    # ── главное меню ──────────────────────────────────────────────────────
    @dp.callback_query(F.data == "main")
    async def cb_main(cb: CallbackQuery, state: FSMContext):
        await state.clear()
        await cb.message.edit_text(
            "📢 <b>Рассылка от лица аккаунта</b>\n\nВыберите действие:",
            parse_mode="HTML", reply_markup=kb_main()
        )

    @dp.callback_query(F.data == "new")
    async def cb_new(cb: CallbackQuery, state: FSMContext):
        await state.clear()
        await cb.message.edit_text(
            "📨 <b>Новая рассылка</b>\n\nВыберите тип:",
            parse_mode="HTML", reply_markup=kb_type()
        )

    # ── выбор типа ────────────────────────────────────────────────────────
    @dp.callback_query(F.data.in_({"t_groups", "t_dm"}))
    async def cb_type(cb: CallbackQuery, state: FSMContext):
        btype = "groups" if cb.data == "t_groups" else "dm"
        await state.update_data(btype=btype)
        label = "группы/каналы" if btype == "groups" else "личные сообщения"
        await state.set_state(S.text)
        await cb.message.edit_text(
            f"✉️ <b>Рассылка → {label}</b>\n\n"
            "Введите текст сообщения.\n"
            "Поддерживается Markdown: **жирный**, __курсив__, `код`",
            parse_mode="HTML", reply_markup=kb_back("new")
        )

    # ── текст сообщения ───────────────────────────────────────────────────
    @dp.message(S.text)
    async def get_text(msg: Message, state: FSMContext):
        await state.update_data(text=msg.text or msg.caption or "")
        data = await state.get_data()
        next_state = S.file_groups if data["btype"] == "groups" else S.file_users
        await state.set_state(next_state)

        hint = (
            "• @username\n• числовой ID (-1001234567890)\n• https://t.me/group"
            if data["btype"] == "groups" else
            "• @username\n• числовой ID пользователя (123456789)"
        )
        await msg.answer(
            f"📁 <b>Загрузите список получателей</b>\n\n"
            f"Отправьте <code>.txt</code> файл <b>или</b> вставьте список прямо сюда.\n\n"
            f"Формат (каждый с новой строки):\n{hint}",
            parse_mode="HTML", reply_markup=kb_back("new")
        )

    # ── файл / текст с получателями для групп ────────────────────────────
    @dp.message(S.file_groups, F.document)
    async def get_groups_doc(msg: Message, state: FSMContext):
        await _load_doc(msg, state)

    @dp.message(S.file_groups)
    async def get_groups_text(msg: Message, state: FSMContext):
        await _load_text(msg, state)

    # ── файл / текст с получателями для ЛС ───────────────────────────────
    @dp.message(S.file_users, F.document)
    async def get_users_doc(msg: Message, state: FSMContext):
        await _load_doc(msg, state)

    @dp.message(S.file_users)
    async def get_users_text(msg: Message, state: FSMContext):
        await _load_text(msg, state)

    # ── вспомогательные функции загрузки ──────────────────────────────────
    async def _load_doc(msg: Message, state: FSMContext):
        if not msg.document.file_name.endswith(".txt"):
            return await msg.answer("⚠️ Нужен <code>.txt</code> файл.", parse_mode="HTML")
        f = await aiogram_bot.get_file(msg.document.file_id)
        raw = (await aiogram_bot.download_file(f.file_path)).read().decode("utf-8")
        targets = parse_targets(raw)
        if not targets:
            return await msg.answer("⚠️ Файл пуст или формат не распознан.")
        await state.update_data(targets=targets)
        await _ask_cooldown(msg, state, len(targets))

    async def _load_text(msg: Message, state: FSMContext):
        targets = parse_targets(msg.text or "")
        if not targets:
            return await msg.answer("⚠️ Получатели не найдены. Проверьте формат.")
        await state.update_data(targets=targets)
        await _ask_cooldown(msg, state, len(targets))

    async def _ask_cooldown(msg: Message, state: FSMContext, count: int):
        await state.set_state(S.cooldown)
        await msg.answer(
            f"✅ Загружено <b>{count}</b> получателей.\n\n"
            "⏱ <b>Кулдаун</b> — задержка между повторными отправками (при возобновлении задачи):",
            parse_mode="HTML", reply_markup=kb_cooldown()
        )

    # ── кулдаун ───────────────────────────────────────────────────────────
    @dp.callback_query(S.cooldown, F.data.startswith("cd_"))
    async def cb_cooldown(cb: CallbackQuery, state: FSMContext):
        if cb.data == "cd_custom":
            await state.set_state(S.cooldown_inp)
            return await cb.message.edit_text(
                "✏️ Введите кулдаун в секундах:", reply_markup=kb_back("new")
            )
        val = int(cb.data.split("_")[1])
        await state.update_data(cooldown=val)
        await state.set_state(S.interval)
        await cb.message.edit_text(
            f"✅ Кулдаун: <b>{val} сек</b>\n\n"
            "⏳ <b>Интервал</b> — пауза между отправкой каждому получателю:",
            parse_mode="HTML", reply_markup=kb_interval()
        )

    @dp.message(S.cooldown_inp)
    async def cooldown_inp(msg: Message, state: FSMContext):
        try:
            val = int(msg.text.strip()); assert val >= 0
        except:
            return await msg.answer("⚠️ Введите целое число ≥ 0.")
        await state.update_data(cooldown=val)
        await state.set_state(S.interval)
        await msg.answer(
            f"✅ Кулдаун: <b>{val} сек</b>\n\n"
            "⏳ <b>Интервал</b> — пауза между отправкой каждому получателю:",
            parse_mode="HTML", reply_markup=kb_interval()
        )

    # ── интервал ──────────────────────────────────────────────────────────
    @dp.callback_query(S.interval, F.data.startswith("iv_"))
    async def cb_interval(cb: CallbackQuery, state: FSMContext):
        if cb.data == "iv_custom":
            await state.set_state(S.interval_inp)
            return await cb.message.edit_text(
                "✏️ Введите интервал в секундах:", reply_markup=kb_back("new")
            )
        val = int(cb.data.split("_")[1])
        await state.update_data(interval=val)
        await _show_confirm(cb.message, state)

    @dp.message(S.interval_inp)
    async def interval_inp(msg: Message, state: FSMContext):
        try:
            val = int(msg.text.strip()); assert val >= 0
        except:
            return await msg.answer("⚠️ Введите целое число ≥ 0.")
        await state.update_data(interval=val)
        await _show_confirm(msg, state)

    # ── подтверждение ─────────────────────────────────────────────────────
    async def _show_confirm(msg_or_cb, state: FSMContext):
        d = await state.get_data()
        preview = d["text"][:120] + ("…" if len(d["text"]) > 120 else "")
        label = "Группы/каналы" if d["btype"] == "groups" else "Личные сообщения"
        txt = (
            "📋 <b>Подтверждение рассылки</b>\n\n"
            f"👤 Отправитель: <b>ваш аккаунт</b>\n"
            f"📌 Тип: <b>{label}</b>\n"
            f"👥 Получателей: <b>{len(d['targets'])}</b>\n"
            f"⏱ Кулдаун: <b>{d['cooldown']} сек</b>\n"
            f"⏳ Интервал: <b>{d['interval']} сек</b>\n\n"
            f"💬 Текст:\n<i>{preview}</i>"
        )
        await state.set_state(S.confirm)
        try:
            await msg_or_cb.edit_text(txt, parse_mode="HTML", reply_markup=kb_confirm())
        except:
            await msg_or_cb.answer(txt, parse_mode="HTML", reply_markup=kb_confirm())

    @dp.callback_query(S.confirm, F.data == "go")
    async def cb_go(cb: CallbackQuery, state: FSMContext):
        d = await state.get_data()
        await state.clear()
        tid = await manager.create(
            btype=d["btype"], targets=d["targets"], text=d["text"],
            cooldown=d["cooldown"], interval=d["interval"],
            notify_id=cb.from_user.id
        )
        await cb.message.edit_text(
            f"🚀 <b>Рассылка запущена!</b>\n\n"
            f"🆔 ID: <code>{tid}</code>\n"
            f"👥 Получателей: <b>{len(d['targets'])}</b>\n\n"
            "Следите за прогрессом в «Активных задачах».",
            parse_mode="HTML", reply_markup=kb_back("main")
        )

    @dp.callback_query(S.confirm, F.data == "cancel")
    async def cb_cancel(cb: CallbackQuery, state: FSMContext):
        await state.clear()
        await cb.message.edit_text("❌ Рассылка отменена.", reply_markup=kb_main())

    # ── управление задачами ───────────────────────────────────────────────
    async def _render_tasks(cb: CallbackQuery):
        tasks = manager.get_tasks()
        if not tasks:
            return await cb.message.edit_text(
                "📋 <b>Активные задачи</b>\n\nЗадач нет.",
                parse_mode="HTML", reply_markup=kb_back("main")
            )
        lines = ["📋 <b>Активные задачи:</b>\n"]
        for tid, t in tasks.items():
            status = "▶️ Активна" if t["running"] else "⏸ Остановлена"
            lines.append(
                f"<code>{tid[:8]}</code> | {status}\n"
                f"  {'Группы' if t['type']=='groups' else 'ЛС'} | "
                f"{t['sent']}/{t['total']} | "
                f"кд {t['cooldown']}с | ин {t['interval']}с\n"
            )
        await cb.message.edit_text(
            "\n".join(lines), parse_mode="HTML", reply_markup=kb_tasks(tasks)
        )

    @dp.callback_query(F.data == "tasks")
    async def cb_tasks(cb: CallbackQuery):
        await _render_tasks(cb)

    @dp.callback_query(F.data.startswith("stop_"))
    async def cb_stop(cb: CallbackQuery):
        manager.stop(cb.data[5:])
        await cb.answer("⏸ Остановлена")
        await _render_tasks(cb)

    @dp.callback_query(F.data.startswith("res_"))
    async def cb_res(cb: CallbackQuery):
        await manager.resume(cb.data[4:])
        await cb.answer("▶️ Возобновлена")
        await _render_tasks(cb)

    @dp.callback_query(F.data.startswith("del_"))
    async def cb_del(cb: CallbackQuery):
        manager.delete(cb.data[4:])
        await cb.answer("🗑 Удалена")
        await _render_tasks(cb)

# ═══════════════════════════════════════════════════════════════════════════════
#  ТОЧКА ВХОДА
# ═══════════════════════════════════════════════════════════════════════════════
async def main():
    # Запускаем Pyrogram (авторизация аккаунта)
    pyro = PyroClient(SESSION_NAME, api_id=API_ID, api_hash=API_HASH)
    await pyro.start()
    me = await pyro.get_me()
    log.info(f"Pyrogram: вошли как {me.first_name} (@{me.username})")

    # Запускаем aiogram-бота для управления
    aiogram_bot = Bot(token=BOT_TOKEN)
    dp = Dispatcher(storage=MemoryStorage())
    manager = BroadcastManager(pyro, aiogram_bot)
    register_handlers(dp, manager, aiogram_bot)

    log.info("Aiogram бот запущен. Управляйте через Telegram.")
    try:
        await dp.start_polling(aiogram_bot)
    finally:
        await pyro.stop()

if __name__ == "__main__":
    asyncio.run(main())
