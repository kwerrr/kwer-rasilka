# ═══════════════════════════════════════════════════════════════════════════════
#  МЕНЕДЖЕР РАССЫЛКИ (Pyrogram)
# ═══════════════════════════════════════════════════════════════════════════════
class BroadcastManager:
    def __init__(self, pyro: PyroClient, aiogram_bot: Bot):
        self.pyro = pyro
        self.bot  = aiogram_bot
        self._tasks: dict[str, dict]               = {}
        self._jobs:  dict[str, asyncio.Task]       = {}

    def get_tasks(self) -> dict:
        return self._tasks

    # ── создание задачи ────────────────────────────────────────────────────
    async def create(self, *, btype, targets, text, cooldown, interval, notify_id) -> str:
        tid = str(uuid.uuid4())
        self._tasks[tid] = dict(
            type=btype, targets=list(targets), remaining=list(targets),
            text=text, cooldown=cooldown, interval=interval,
            notify_id=notify_id, sent=0, failed=0,
            total=len(targets), running=True,
        )
        self._jobs[tid] = asyncio.create_task(self._run(tid))
        return tid

    # ── основной цикл ──────────────────────────────────────────────────────
    async def _run(self, tid: str):
        t = self._tasks[tid]
        log.info(f"[{tid[:8]}] Start — {t['total']} targets, interval={t['interval']}s")

        while t["remaining"] and t["running"]:
            target = t["remaining"][0]
            ok = await self._send(t["text"], target)
            t["remaining"].pop(0)
            if ok:
                t["sent"] += 1
            else:
                t["failed"] += 1

            if t["remaining"] and t["running"]:
                await asyncio.sleep(t["interval"])

        t["running"] = False
        log.info(f"[{tid[:8]}] Done — sent={t['sent']} failed={t['failed']}")

        try:
            await self.bot.send_message(
                t["notify_id"],
                f"✅ <b>Рассылка завершена</b>\n\n"
                f"🆔 <code>{tid}</code>\n"
                f"📤 Отправлено: <b>{t['sent']}</b>\n"
                f"❌ Ошибок: <b>{t['failed']}</b>\n"
                f"📊 Всего: <b>{t['total']}</b>",
                parse_mode="HTML"
            )
        except Exception:
            pass

    # ── отправка одного сообщения через аккаунт ────────────────────────────
    async def _send(self, text: str, target) -> bool:
        try:
            await self.pyro.send_message(target, text)
            return True

        except FloodWait as e:
            log.warning(f"FloodWait {e.value}s for {target}")
            await asyncio.sleep(e.value)
            return await self._send(text, target)   # повтор после ожидания

        except (UserPrivacyRestricted, UserIsBlocked, InputUserDeactivated):
            log.info(f"Skip {target}: privacy/blocked/deactivated")
            return False

        except (PeerIdInvalid, UsernameNotOccupied):
            log.warning(f"Skip {target}: invalid peer")
            return False

        except (ChatWriteForbidden, UserBannedInChannel):
            log.warning(f"Skip {target}: write forbidden")
            return False

        except Exception as e:
            log.error(f"Error sending to {target}: {e}")
            return False

    # ── управление задачами ────────────────────────────────────────────────
    def stop(self, tid: str):
        if tid in self._tasks:
            self._tasks[tid]["running"] = False
        if tid in self._jobs:
            self._jobs[tid].cancel()

    async def resume(self, tid: str):
        t = self._tasks.get(tid)
        if not t or t["running"]:
            return
        # Пересчитываем оставшихся (со смещением по cooldown — просто продолжаем с места)
        t["remaining"] = t["targets"][t["sent"] + t["failed"]:]
        t["running"] = True
        self._jobs[tid] = asyncio.create_task(self._run(tid))

    def delete(self, tid: str):
        self.stop(tid)
        self._tasks.pop(tid, None)
        self._jobs.pop(tid, None)

