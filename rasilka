#  УТИЛИТЫ — парсинг файлов
# ═══════════════════════════════════════════════════════════════════════════════
def parse_targets(raw: str) -> list:
    """Парсит @username, числовые ID и t.me/-ссылки из многострочного текста."""
    result = []
    for line in raw.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        # t.me/username
        m = re.search(r"t\.me/([a-zA-Z0-9_]+)", line)
        if m:
            result.append("@" + m.group(1))
            continue
        # числовой ID (положительный или отрицательный)
        if re.match(r"^-?\d+$", line):
            result.append(int(line))
            continue
        # @username или username
        if re.match(r"^@?[a-zA-Z0-9_]{4,32}$", line):
            result.append(line if line.startswith("@") else "@" + line)
    return result

